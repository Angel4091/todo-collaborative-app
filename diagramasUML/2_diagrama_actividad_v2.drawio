        </mxCell>

        <mxCell id="act_crear" parent="lane_sys" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;rounded=1;" value="Crear un TaskWorker por colaborador envuelto en su propio Thread" vertex="1">

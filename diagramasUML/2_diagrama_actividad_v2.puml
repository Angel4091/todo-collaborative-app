@startuml DiagramaActividadV2
title Diagrama de Actividad - Cambiar estado de Task con concurrencia

|Hilo Maria|
start
fork
  :Crear TaskWorker(task, IN_PROGRESS, maria);
  :Iniciar hilo (Thread.start());
  :Ejecutar run();
  :Llamar modifyStatus(IN_PROGRESS) [synchronized];
  :Actualizar status a IN_PROGRESS;
  :Mostrar informacion;
fork again
  |Hilo Pedro|
  :Crear TaskWorker(task, COMPLETED, pedro);
  :Iniciar hilo (Thread.start());
  :Ejecutar run();
  :Llamar modifyStatus(COMPLETED) [synchronized];
  :Actualizar status a COMPLETED;
  :Mostrar informacion;
end fork
stop

@enduml

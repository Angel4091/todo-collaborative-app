@startuml DiagramaActividadV2
title Diagrama de Actividad - Cambiar estado de Task con concurrencia

|TaskWorker|
start
:Crear hilos Maria y Pedro;
fork
  :Ejecutar run() [Hilo Maria];
  :Llamar modifyStatus(IN_PROGRESS);
fork again
  :Ejecutar run() [Hilo Pedro];
  :Llamar modifyStatus(COMPLETED);
end fork

|Task|
if (Monitor disponible?) then (Si)
  :Entrar synchronized(this);
  :Actualizar status;
  :Mostrar informacion;
else (No)
  :Esperar a que se libere el monitor;
  -[hidden]->
endif

|TaskWorker|
stop

@enduml

@startuml DiagramaActividadV2
title Diagrama de Actividad v2 - Flujo de gestion de tareas con concurrencia\n(Entregable 2 - Patron Strategy + Threads)

|Usuario|
start
:Autenticarse en el sistema;

|Sistema|
if (Credenciales validas?) then (no)
  :Mostrar error;
  stop
else (si)
endif

|Usuario|
:Elegir operacion sobre el item;

|Sistema|
switch (Operacion?)
case (Crear Task)
  :Generar id con AtomicInteger;
  :task = new Task(id, titulo, desc, prioridad, owner);
  note right
    Sin Factory: el cliente
    instancia Task directamente.
    status inicial = PENDING.
  end note
  :owner.addItem(task);
  if (owner es ClassicUser y supera limitTask?) then (si)
    :Rechazar y retornar false;
    stop
  else (no)
  endif
  :items.put(task.id, task) en ConcurrentHashMap;

case (Crear Reminder)
  :Generar id con AtomicInteger;
  :reminder = new Reminder(id, titulo, desc, prioridad, owner, dateTime);
  :Seleccionar NotificationStrategy
   (EmailNotification o MensajeTextoNotification);
  note right
    PATRON STRATEGY: la estrategia
    de notificacion se inyecta en
    tiempo de ejecucion via
    reminder.setNotificationStrategy()
  end note
  :reminder.setNotificationStrategy(strategy);
  :owner.addItem(reminder);
  :items.put(reminder.id, reminder);

case (Compartir item)
  if (Es el owner del item?) then (no)
    :Solo el owner puede compartir;
    stop
  else (si)
  endif
  if (owner es ClassicUser y supera maxCollaborators?) then (si)
    :Rechazar y retornar false;
    stop
  else (no)
  endif
  :item.addCollaborator(colab) [synchronized];
  note right
    synchronized garantiza que dos
    hilos no agreguen colaboradores
    al mismo item al mismo tiempo.
    Internamente tambien actualiza
    colab.sharedItems.
  end note

case (Cambiar estado de Task)
  ' === EJECUCION CONCURRENTE ===
  fork
    |Hilo Maria|
    :TaskWorker(task, IN_PROGRESS, maria).run();
    :task.modifyStatus(IN_PROGRESS)
     [synchronized];
  fork again
    |Hilo Pedro|
    :TaskWorker(task, COMPLETED, pedro).run();
    :task.modifyStatus(COMPLETED)
     [synchronized];
  end fork
  |Sistema|
  :Solo un hilo entra a la
   seccion critica a la vez;
  note right
    CONCURRENCIA: aunque varios
    hilos llamen modifyStatus en
    paralelo sobre la misma Task,
    el monitor (synchronized) los
    serializa. El ultimo en entrar
    deja el estado final.
  end note

case (Disparar alerta Reminder)
  :reminder.notifyAlert();
  :strategy.notify(mensaje);
  note right
    Aqui se ve Strategy en accion:
    el mismo notifyAlert() despacha
    a Email o Mensaje de Texto
    segun la estrategia asignada.
  end note

endswitch

:Operacion completada;
stop

@enduml

@startuml DiagramaActividadV2
title Diagrama de Actividad - Cambiar estado de Task con concurrencia

|TaskWorker|
start
fork
  :run() [Hilo Maria];
  :Llamar modifyStatus(IN_PROGRESS);
fork again
  :run() [Hilo Pedro];
  :Llamar modifyStatus(COMPLETED);
end fork

|Task|
:Entrar synchronized(this);
:Actualizar status;
:Mostrar informacion;
stop

@enduml

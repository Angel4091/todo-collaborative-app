@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia - Cambiar estado de Task con concurrencia

actor Usuario
participant ":TaskWorker\n(Maria)" as wMaria
participant ":TaskWorker\n(Pedro)" as wPedro
participant "task:Task" as task

== Cambio de estado - Hilo Maria ==

par [Hilo 1 ejecuta]
  Usuario -> wMaria : start()
  activate wMaria
  wMaria -> task : modifyStatus(IN_PROGRESS)
  activate task
  task -> task : status = "IN_PROGRESS"
  task -> task : mostrarInformacion()
  deactivate task
  deactivate wMaria
end

== Cambio de estado - Hilo Pedro ==

par [Hilo 2 ejecuta]
  Usuario -> wPedro : start()
  activate wPedro
  wPedro -> task : modifyStatus(COMPLETED)
  activate task
  task -> task : status = "COMPLETED"
  task -> task : mostrarInformacion()
  deactivate task
  deactivate wPedro
end

@enduml

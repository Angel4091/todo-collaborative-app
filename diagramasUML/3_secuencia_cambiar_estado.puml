@startuml SecuenciaCambiarEstado

skinparam noteBackgroundColor #FFF2CC
skinparam noteBorderColor #D6B656

actor Maria
actor Pedro
participant "task:Task" as task

note left of Maria #FFF2CC
  Diagrama de
  Secuencia
end note

Maria -> task : solicitarCambio(IN_PROGRESS)
task --> Maria : aceptado
Pedro -> task : solicitarCambio(COMPLETED)
task --> Pedro : aceptado

Maria -> Maria : prepararHilo()
Pedro -> Pedro : prepararHilo()

par hilo Maria
  Maria -> task : modifyStatus(IN_PROGRESS)
  activate task
  task -> task : synchronized(this)
  task -> task : status = IN_PROGRESS
  task -> task : log "PENDING -> IN_PROGRESS"
  task --> Maria : ok
  deactivate task
else hilo Pedro
  loop [monitor ocupado]
    Pedro -> task : intentar modifyStatus
    task --> Pedro : esperar
  end
  Pedro -> task : modifyStatus(COMPLETED)
  activate task
  task -> task : synchronized(this)
  task -> task : status = COMPLETED
  task -> task : log "IN_PROGRESS -> COMPLETED"
  task --> Pedro : ok
  deactivate task
end

note right of task
  synchronized en Task.modifyStatus
  garantiza que solo un hilo entre a
  la seccion critica a la vez. El
  otro espera (loop) y entra cuando
  se libera el monitor.
end note

@enduml

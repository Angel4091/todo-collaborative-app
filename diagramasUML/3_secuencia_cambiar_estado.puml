@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia - Cambiar estado de Task con concurrencia\n(estructura par + loop + alt, con nuestras clases)

actor User1
participant ":MainMenu" as menu1
participant ":MainMenu" as menu2
participant "task:Task" as task
participant "hiloA :\nTaskWorker" as hiloA
participant "hiloB :\nTaskWorker" as hiloB
actor User2

User1 -> menu1 : cambiar estado de Task
menu1 -> menu1 : indexMenu()

User2 -> menu2 : cambiar estado de Task

menu1 -> hiloA : User1 : startThread(task, IN_PROGRESS)
menu2 -> hiloB : User2 : startThread(task, COMPLETED)

par
  hiloA -> task : modifyStatus(IN_PROGRESS)
  task -> task : synchronized(this)
  task -> task : status = IN_PROGRESS
  task -> task : log "PENDING -> IN_PROGRESS"
  task --> hiloA : ok
end

loop Repetir hasta que el monitor este libre
  hiloB -> task : modifyStatus(COMPLETED)
  task --> hiloB : monitor ocupado
end

alt Monitor libre
  hiloB -> task : modifyStatus(COMPLETED)
  task -> task : synchronized(this)
  task -> task : status = COMPLETED
  task -> task : log "IN_PROGRESS -> COMPLETED"
  task --> hiloB : ok
else Monitor ocupado
  hiloB -> hiloB : wait()
end

task --> User1 : notifyChange(task)
task --> User2 : notifyChange(task)

menu1 --> User1 : estado cambiado
menu2 --> User2 : estado cambiado

@enduml

@startuml SecuenciaCambiarEstado

skinparam noteBackgroundColor #FFF2CC
skinparam noteBorderColor #D6B656

actor "Angel\n(owner)" as Angel
actor "Maria\n(colaboradora)" as Maria
actor "Pedro\n(colaborador)" as Pedro
participant "task:Task" as task

note left of Angel #FFF2CC
  Diagrama de
  Secuencia
end note

== 1. Crear Task ==

Angel -> task : new Task("Sprint Review", HIGH, Angel)
activate task
note right of task
  Task creada con Angel como
  owner. Estado inicial: PENDING.
end note
task --> Angel : task creada (id=1)
deactivate task

== 2. Compartir Task con colaboradores ==

Angel -> task : addCollaborator(Maria)
activate task
task --> Maria : agregada como colaboradora
task --> Angel : ok
deactivate task

Angel -> task : addCollaborator(Pedro)
activate task
task --> Pedro : agregado como colaborador
task --> Angel : ok
deactivate task

== 3. Cambiar estado concurrentemente ==

par hilo Maria
    Maria -> task : modifyStatus(IN_PROGRESS) <<synchronized>>
    activate task #LightGreen
    note right of task
      Maria adquiere el monitor.
      Pedro quedara BLOCKED hasta
      que se libere.
    end note
    task -> task : status = IN_PROGRESS
    task --> Maria
    deactivate task
else hilo Pedro
    Pedro -> task : modifyStatus(COMPLETED) <<synchronized>>
    note over Pedro #FFE6E6
      Pedro queda en estado
      BLOCKED esperando el
      monitor de 'task'.
    end note
    activate task #LightBlue
    note right of task
      Maria libera el monitor;
      el JVM despierta a Pedro
      automaticamente.
    end note
    task -> task : status = COMPLETED
    task --> Pedro
    deactivate task
end

note over task
  modifyStatus() es synchronized.
  El JVM serializa los hilos via el
  monitor del objeto. Sin retry manual.
end note

@enduml

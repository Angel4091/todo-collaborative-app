@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia - Cambiar estado de Task con concurrencia\n(Threads paralelos + synchronized)

participant ":DemoRunner" as demo
participant ":TaskWorker\n(Maria)" as w1
participant ":TaskWorker\n(Pedro)" as w2
participant "task:Task\n(compartida)" as task

demo -> w1 : new TaskWorker(task, IN_PROGRESS, maria) + Thread.start()
activate w1
demo -> w2 : new TaskWorker(task, COMPLETED, pedro) + Thread.start()
activate w2

par ejecucion paralela
  w1 -> task : modifyStatus(IN_PROGRESS)
  activate task
  note right of task
    PRIMER hilo en obtener
    el monitor de 'task'.
    El otro queda esperando.
  end note
  task -> task : synchronized(this)
  task -> task : status = IN_PROGRESS
  task --> w1
  deactivate task
  deactivate w1
else
  w2 -> task : modifyStatus(COMPLETED)
  activate task
  note right of task
    SEGUNDO hilo: entra al
    liberarse el monitor.
    Sin estado corrupto.
  end note
  task -> task : synchronized(this)
  task -> task : status = COMPLETED
  task --> w2
  deactivate task
  deactivate w2
end

demo -> demo : h1.join(); h2.join();
demo -> task : showDetails()
activate task
task --> demo : estado final = COMPLETED
deactivate task

@enduml

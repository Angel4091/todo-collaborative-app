@startuml SecuenciaCambiarEstado
title Secuencia - Cambiar estado de Task con concurrencia

skinparam noteBackgroundColor #FFF2CC
skinparam noteBorderColor #D6B656

actor "Usuario" as U
participant ":MainMenu" as menu
participant "task:Task" as task
participant ":TaskWorker" as worker

U -> menu : cambiarEstado(task)
activate menu

menu -> task : crear y compartir con Maria y Pedro
activate task
task --> menu : ok
deactivate task

menu -> worker : crear 2 hilos y start()
activate worker

par hilo Maria
    worker -> task : modifyStatus(IN_PROGRESS) <<synchronized>>
    activate task #LightGreen
    note right of task
      Maria adquiere el monitor.
      Pedro queda BLOCKED.
    end note
    task -> task : status = IN_PROGRESS
    task --> worker
    deactivate task
else hilo Pedro
    worker -> task : modifyStatus(COMPLETED) <<synchronized>>
    activate task #LightBlue
    note right of task
      Maria libera el monitor;
      Pedro entra automaticamente.
    end note
    task -> task : status = COMPLETED
    task --> worker
    deactivate task
end

deactivate worker

menu -> task : showDetails()
task --> menu : estado final = COMPLETED

menu --> U : Fin
deactivate menu

@enduml

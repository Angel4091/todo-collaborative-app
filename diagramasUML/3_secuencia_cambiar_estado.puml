@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia - Cambiar estado de Task con concurrencia

participant ":MainMenu" as demo
participant "task:Task" as task
participant "hiloA :\nTaskWorker" as hiloA
participant "hiloB :\nTaskWorker" as hiloB

demo -> hiloA : startThread(task, IN_PROGRESS)
demo -> hiloB : startThread(task, COMPLETED)

par
  hiloA -> task : modifyStatus(IN_PROGRESS)
  activate task
  task -> task : synchronized(this)
  task -> task : status = IN_PROGRESS
  task -> task : log "PENDING -> IN_PROGRESS"
  task --> hiloA : ok
  deactivate task
end

loop Repetir hasta que el monitor este libre
  hiloB -> task : modifyStatus(COMPLETED)
  task --> hiloB : monitor ocupado
end

alt Monitor libre
  hiloB -> task : modifyStatus(COMPLETED)
  activate task
  task -> task : synchronized(this)
  task -> task : status = COMPLETED
  task -> task : log "IN_PROGRESS -> COMPLETED"
  task --> hiloB : ok
  deactivate task
else Monitor ocupado
  hiloB -> hiloB : wait()
end

@enduml

@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia - Cambiar estado de Task con concurrencia

participant TaskWorker
participant Task

par Hilo Maria
  TaskWorker -> TaskWorker : new TaskWorker(task, IN_PROGRESS, maria)
  activate TaskWorker #LightBlue
  TaskWorker -> TaskWorker : Thread.start()
  TaskWorker -> TaskWorker : run()
  TaskWorker -> TaskWorker : Thread.sleep(100)
  TaskWorker -> Task : modifyStatus(IN_PROGRESS)
  activate Task #LightYellow
  Task -> Task : synchronized(this)
  Task -> Task : oldStatus = PENDING
  Task -> Task : this.status = IN_PROGRESS
  Task -> Task : log "PENDING -> IN_PROGRESS"
  Task --> TaskWorker
  deactivate Task
  deactivate TaskWorker
else Hilo Pedro
  TaskWorker -> TaskWorker : new TaskWorker(task, COMPLETED, pedro)
  activate TaskWorker #LightBlue
  TaskWorker -> TaskWorker : Thread.start()
  TaskWorker -> TaskWorker : run()
  TaskWorker -> TaskWorker : Thread.sleep(100)
  TaskWorker -> Task : modifyStatus(COMPLETED)
  activate Task #LightYellow
  Task -> Task : synchronized(this)
  Task -> Task : oldStatus = IN_PROGRESS
  Task -> Task : this.status = COMPLETED
  Task -> Task : log "IN_PROGRESS -> COMPLETED"
  Task --> TaskWorker
  deactivate Task
  deactivate TaskWorker
end

note over Task
  modifyStatus() es synchronized:
  los hilos se serializan en el monitor.
  No hay race condition.
end note

@enduml

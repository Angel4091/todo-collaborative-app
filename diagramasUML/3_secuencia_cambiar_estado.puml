@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia\nCambiar estado de Task con concurrencia

participant ":TaskWorker" as worker
participant "task:Task" as task

par Hilo-Maria
  worker -> task : modifyStatus(IN_PROGRESS)
  task --> worker
else Hilo-Pedro
  worker -> task : modifyStatus(COMPLETED)
  task --> worker
end

note over task
  modifyStatus() es synchronized:
  solo un hilo entra al monitor,
  el otro espera. Sin race condition.
end note

@enduml

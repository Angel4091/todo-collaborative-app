@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia - Cambiar estado de Task con concurrencia\n(basado en el diagrama de actividad)

participant TaskWorker
participant Task

TaskWorker -> TaskWorker : Crear hilos Maria y Pedro
activate TaskWorker #LightBlue

par Hilo Maria
  TaskWorker -> TaskWorker : Ejecutar run()
  TaskWorker -> Task : Llamar modifyStatus(IN_PROGRESS)
  activate Task #LightYellow
  alt Monitor disponible
    Task -> Task : Entrar synchronized(this)
    Task -> Task : Actualizar status = IN_PROGRESS
    Task -> Task : Mostrar informacion
  else No disponible
    Task -> Task : Esperar a que se libere el monitor
  end
  Task --> TaskWorker
  deactivate Task
else Hilo Pedro
  TaskWorker -> TaskWorker : Ejecutar run()
  TaskWorker -> Task : Llamar modifyStatus(COMPLETED)
  activate Task #LightYellow
  alt Monitor disponible
    Task -> Task : Entrar synchronized(this)
    Task -> Task : Actualizar status = COMPLETED
    Task -> Task : Mostrar informacion
  else No disponible
    Task -> Task : Esperar a que se libere el monitor
  end
  Task --> TaskWorker
  deactivate Task
end
deactivate TaskWorker

@enduml

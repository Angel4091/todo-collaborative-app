@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia - Cambiar estado de Task con concurrencia

participant TaskWorker
participant Task

par Hilo Maria
  TaskWorker -> Task : modifyStatus(IN_PROGRESS)
  activate Task
  Task -> Task : synchronized(this)
  Task -> Task : status = IN_PROGRESS
  Task -> Task : mostrarInformacion()
  Task --> TaskWorker
  deactivate Task
else Hilo Pedro
  TaskWorker -> Task : modifyStatus(COMPLETED)
  activate Task
  Task -> Task : synchronized(this)
  Task -> Task : status = COMPLETED
  Task -> Task : mostrarInformacion()
  Task --> TaskWorker
  deactivate Task
end

note over Task
  modifyStatus() es synchronized:
  los hilos se serializan en el
  monitor. No hay race condition.
end note

@enduml

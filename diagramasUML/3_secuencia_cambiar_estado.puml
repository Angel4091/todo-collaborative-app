@startuml SecuenciaCambiarEstado
title Diagrama de Secuencia - Cambiar estado de Task con concurrencia\n(basado en la referencia: par + loop + alt)

actor User1
participant ":MainMenu" as menu1
participant ":MainMenu" as menu2
participant "task:Task" as task
participant "hiloA :\nTaskWorker" as hiloA
participant "hiloB :\nTaskWorker" as hiloB
actor User2

User1 -> menu1 : request change of status
menu1 -> menu1 : indexMenu()

User2 -> menu2 : request change of status

menu1 -> hiloA : User1 : startThread(task, state)
menu2 -> hiloB : User2 : startThread(task, state)

par
  hiloA -> task : checkAvailability()
  task --> hiloA : return true
  hiloA -> task : lockTask(task)
  task --> hiloA : locked
  hiloA -> task : changeState(newState)
  hiloA -> task : unlockTask(task)
  task --> hiloA : unlocked
end

loop Repetir hasta que la task este disponible
  hiloB -> task : checkAvailability()
  task --> hiloB : return true
end

alt Available task
  hiloB -> task : lockTask(task)
  task --> hiloB : locked
  hiloB -> task : changeState(newState)
  hiloB -> task : unlockTask(task)
  task --> hiloB : unlocked
else Busy task
  hiloB -> hiloB : wait()
end

task --> User1 : notifyChange(task)
task --> User2 : notifyChange(task)

menu1 --> User1 : stateChange
menu2 --> User2 : stateChange

@enduml

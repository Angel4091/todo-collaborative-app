@startuml DiagramaObjetos
title Diagrama de Objetos\nBasado en el diagrama de clases v2 (Strategy + Concurrencia)

skinparam noteBackgroundColor #FFF2CC
skinparam noteBorderColor #D6B656

' ============================================
' INSTANCIAS DE LA JERARQUIA User
' (PremiumUser y ClassicUser extienden User)
' ============================================
object "angel : PremiumUser" as angel {
  id = 1
  name = "Angel"
  email = "angel@mail.com"
}

object "maria : ClassicUser" as maria {
  id = 2
  name = "Maria"
  email = "maria@mail.com"
  limitTask = 5
  maxCollaborators = 3
}

object "pedro : ClassicUser" as pedro {
  id = 3
  name = "Pedro"
  email = "pedro@mail.com"
  limitTask = 5
  maxCollaborators = 3
}

' ============================================
' INSTANCIAS DE LA JERARQUIA Item
' (Task y Reminder extienden Item)
' ============================================
object "t1 : Task" as t1 {
  id = 1
  title = "Sprint Review"
  description = "Demo del proyecto"
  priority = HIGH
  status = IN_PROGRESS
}

object "r1 : Reminder" as r1 {
  id = 2
  title = "Reunion con cliente"
  description = "Mostrar el demo"
  priority = MEDIUM
  dateTime = "2026-05-20 14:00"
}

' ============================================
' INSTANCIA DE NotificationStrategy (Strategy)
' ============================================
object "emailStrat : EmailNotification" as email

' ============================================
' INSTANCIAS DE TaskWorker (concurrencia)
' Implementan Runnable y modifican Task
' ============================================
object "workerMaria : TaskWorker" as wm {
  newStatus = IN_PROGRESS
}

object "workerPedro : TaskWorker" as wp {
  newStatus = COMPLETED
}

' ============================================
' LINKS - reflejan las relaciones del diagrama de clases
' ============================================

' User "1" o-- "0..*" Item : posee
angel --> t1 : createdItems
angel --> r1 : createdItems
t1 --> angel : owner
r1 --> angel : owner

' Item.collaborators (Shareable)
t1 --> maria : collaborators
t1 --> pedro : collaborators
maria --> t1 : sharedItems
pedro --> t1 : sharedItems

' Reminder "1" o-- "1" NotificationStrategy : usa
r1 --> email : notificationStrategy

' TaskWorker ..> Task : modifica concurrentemente
wm ..> t1 : task
wp ..> t1 : task

' TaskWorker ..> User : representa
wm ..> maria : user
wp ..> pedro : user

' ============================================
' NOTAS
' ============================================
note bottom of t1
  Despues de que workerMaria y
  workerPedro corrieran en hilos
  paralelos, Maria entro primero
  al synchronized. El status final
  quedo en IN_PROGRESS.
end note

note right of email
  PATRON STRATEGY:
  r1 puede cambiar de EmailNotification
  a MensajeTextoNotification en runtime
  sin tocar la clase Reminder.
end note

note bottom of wp
  Los dos TaskWorker compiten por
  el monitor de t1. synchronized en
  Task.modifyStatus los serializa
  automaticamente.
end note

@enduml
